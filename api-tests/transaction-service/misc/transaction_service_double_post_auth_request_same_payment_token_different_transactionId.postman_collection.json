{
  "info": {
    "_postman_id": "dc249b68-8104-42d2-bf64-d05dbc6cb304",
    "name": "Transaction service for local eCommerce - double post auth request same payment token different transactionId",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "23963988",
    "_collection_link": "https://go.postman.co/collection/23963988-dc249b68-8104-42d2-bf64-d05dbc6cb304?source=collection_link"
  },
  "item": [
    {
      "name": "New transaction",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"[pagopa-ecommerce-transaction-service] Activate new transaction V2 (status code 200)\", () => {",
              "    const responseJson = pm.response.json();",
              "    const transactionId = responseJson.transactionId;",
              "    pm.environment.set(\"TRANSACTION_ID\", transactionId);",
              "    pm.response.to.have.status(200);",
              "    pm.environment.set(\"ACTIVATION_PAYMENT_NOTICES\", JSON.stringify(responseJson.payments));",
              "});",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "function createSession(paymentMethodId) {",
              "    const createSession = {",
              "        url: `${pm.environment.get(\"HOSTNAME\")}:${pm.environment.get(\"PAYMENT_METHOD_SERVICE_PORT\")}/payment-methods/${paymentMethodId}/sessions`,",
              "        method: 'POST',",
              "        header: {",
              "            'Content-Type': 'application/json',",
              "            'x-api-key': 'PRIMARY-KEY'",
              "        },",
              "        body: {",
              "            mode: 'raw',",
              "            raw: ''",
              "        }",
              "    };",
              "",
              "    pm.sendRequest(createSession, (error, response) => {",
              "        if (error) {",
              "            console.log(`Create session error: ${error.code}`);",
              "        } else {",
              "            const responseBody = response.json();",
              "            pm.environment.set(\"ORDER_ID\", responseBody.orderId);",
              "            pm.environment.set(\"CORRELATION_ID\", responseBody.correlationId);",
              "        }",
              "    });",
              "}",
              "const paymentMethodId = \"378d0b4f-8b69-46b0-8215-07785fe1aad4\";",
              "pm.environment.set(\"PAYMENT_METHOD_ID\", paymentMethodId);",
              "createSession(paymentMethodId);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "apikey",
          "apikey": [
            {
              "key": "value",
              "value": "{{PRIMARY_API_KEY}}",
              "type": "string"
            },
            {
              "key": "key",
              "value": "x-api-key",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "x-client-id",
            "value": "CHECKOUT"
          },
          {
            "key": "x-correlation-id",
            "value": "{{CORRELATION_ID}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"emailToken\": \"{{EMAIL_TOKEN}}\",\n    \"paymentNotices\": [{\n        \"rptId\": \"77777777777302099999999999999\",\n        \"amount\": {{AMOUNT}}\n    }],\n    \"orderId\": \"{{ORDER_ID}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{HOSTNAME}}:{{TRANSACTION_SERVICE_PORT}}/v2.1/transactions",
          "host": [
            "{{HOSTNAME}}"
          ],
          "port": "{{TRANSACTION_SERVICE_PORT}}",
          "path": [
            "v2.1",
            "transactions"
          ]
        }
      },
      "response": []
    },
