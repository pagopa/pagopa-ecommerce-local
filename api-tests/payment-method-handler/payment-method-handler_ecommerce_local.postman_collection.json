					"const res = pm.response.json();",
					"",
					"pm.test(\"Response has all required fields with correct types\", function () {",
					"    pm.expect(res).to.have.property(\"paymentMethodName\").and.is.a(\"string\");",
					"    pm.expect(res).to.have.property(\"paymentMethodDescription\").and.is.a(\"string\");",
					"    pm.expect(res).to.have.property(\"paymentMethodStatus\").and.is.a(\"string\");",
					"    pm.expect(res).to.have.property(\"bundles\").and.is.an(\"array\");",
					"    pm.expect(res).to.have.property(\"asset\").and.is.a(\"string\");",
					"    pm.expect([\"ENABLED\",\"DISABLED\",\"MAINTENANCE\"]).to.include(res.paymentMethodStatus);",
					"    pm.expect(res.asset).to.match(/^https?:\\/\\//);",
					"});",
					"",
					"pm.test(\"Bundles array is not empty\", function () {",
					"    pm.expect(res.bundles).to.not.be.empty;",
					"});",
					"",
					"pm.test(\"Each bundle has required fields with correct types\", function () {",
					"    res.bundles.forEach(function (bundle) {",
					"        pm.expect(bundle).to.have.property(\"idBundle\").and.is.a(\"string\");",
					"        pm.expect(bundle).to.have.property(\"idPsp\").and.is.a(\"string\");",
					"        pm.expect(bundle).to.have.property(\"taxPayerFee\").and.is.a(\"number\");",
					"        pm.expect(bundle).to.have.property(\"idChannel\").and.is.a(\"string\");",
					"        pm.expect(bundle).to.have.property(\"touchpoint\").and.is.a(\"string\");",
					"        pm.expect(bundle.taxPayerFee).to.be.at.least(0);",
					"    });",
					"});",
					"",
					"pm.test(\"belowThreshold is boolean if present\", function () {",
					"    if (res.hasOwnProperty(\"belowThreshold\")) {",
					"        pm.expect(res.belowThreshold).to.be.a(\"boolean\");",
					"    }",
					"});",
					"",
					"pm.test(\"brandAssets values are strings if present\", function () {",
					"    if (res.hasOwnProperty(\"brandAssets\")) {",
					"        pm.expect(res.brandAssets).to.be.an(\"object\");",
					"        Object.values(res.brandAssets).forEach(v => {",
					"            pm.expect(v).to.be.a(\"string\");",
					"        });",
					"    }",
					"});",
					"",
					"pm.test(\"pspBusinessName is a string when present (bundleName is deprecated)\", function () {",
