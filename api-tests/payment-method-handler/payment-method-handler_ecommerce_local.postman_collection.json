			{
			"name": "Calculate Fees for Payment Method for CHECKOUT (Multi Notice) [200]",
			"event": [
				{
				"listen": "test",
				"script": {
					"exec": [
					"pm.test(\"Status code is 200 OK\", function () {",
					"    pm.response.to.have.status(200);",
					"});",
					"",
					"const res = pm.response.json();",
					"",
					"pm.test(\"Bundles array is not empty\", function () {",
					"    pm.expect(res.bundles).to.be.an(\"array\").and.not.be.empty;",
					"});",
					"",
					"pm.test(\"Each bundle taxPayerFee is non-negative\", function () {",
					"    res.bundles.forEach(function (bundle) {",
					"        pm.expect(bundle.taxPayerFee).to.be.at.least(0);",
					"    });",
					"});"
					],
					"type": "text/javascript"
				}
				}
			],
			"request": {
				"method": "POST",
				"header": [
				{
					"key": "x-client-id",
					"value": "CHECKOUT",
					"type": "text"
				},
				{ 
					"key": "x-language", 
					"value": "IT", 
					"type": "text" 
				}
				],
				"body": {
				"mode": "raw",
				"raw": "{\n  \"touchpoint\": \"CHECKOUT\",\n  \"isAllCCP\": false,\n  \"paymentNotices\": [\n    {\n      \"paymentAmount\": 5000,\n      \"primaryCreditorInstitution\": \"PA_FISCAL_CODE_1\",\n      \"transferList\": [\n        {\n          \"creditorInstitution\": \"PA_FISCAL_CODE_1\",\n          \"transferCategory\": \"TAX\",\n          \"digitalStamp\": false\n        }\n      ]\n    },\n    {\n      \"paymentAmount\": 10050,\n      \"primaryCreditorInstitution\": \"PA_FISCAL_CODE_2\",\n      \"transferList\": [\n        {\n          \"creditorInstitution\": \"PA_FISCAL_CODE_2\",\n          \"transferCategory\": \"TAX\",\n          \"digitalStamp\": false\n        }\n      ]\n    }\n  ]\n}",
