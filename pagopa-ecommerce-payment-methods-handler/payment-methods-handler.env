# Quarkus / OpenTelemetry Config
# disable Quarkus native OpenTelemetry (use Java agent instead)
QUARKUS_OTEL_SDK_DISABLED=true

# OpenTelemetry configuration for SigNoz
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_SAMPLER=always_on
OTEL_SERVICE_NAME=ecommerce-payment-methods-handler
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Logging Config
ECS_SERVICE_NAME=pagopa-ecommerce-payment-methods-handler
ECS_SERVICE_ENVIRONMENT=dev
ROOT_LOG_LEVEL=INFO

# Security / API Key Config
SECURITY_API_KEY_SECURED_PATHS="/payment-methods,/npg/sdk/integrity"
SECURITY_API_KEY_PRIMARY=PRIMARY-KEY
SECURITY_API_KEY_SECONDARY=SECONDARY-KEY

# AFM (Fee Calculator) Config
AFM_URI_V1="http://pagopa-gec-mock:3000"
AFM_URI_V2="http://pagopa-gec-mock:3000"
AFM_KEY=sub-key
AFM_CONNECTION_TIMEOUT=10000
AFM_READ_TIMEOUT=5000

# NPG B2B Client Config (SDK Integrity)
NPG_B2B_URI=http://pagopa-npg-mock:3000
NPG_B2B_CONNECTION_TIMEOUT=5000
NPG_B2B_READ_TIMEOUT=10000

# NPG Payment Sessions Config
NPG_URI=http://pagopa-npg-mock:3000/
NPG_API_KEY=test-api-key
NPG_SESSIONS_TTL=600
NPG_NOTIFICATION_JWT_VALIDITY_TIME=900

# JWT Issuer Config
JWT_ISSUER_URI=http://pagopa-jwt-issuer-mock:3000
JWT_ISSUER_CONNECTION_TIMEOUT=10000
JWT_ISSUER_READ_TIMEOUT=10000
JWT_ISSUER_API_KEY=PRIMARY-KEY

# Session URL Config
SESSION_URL_BASE_PATH=https://localhost:1234
SESSION_URL_IO_BASE_PATH=https://localhost:1234
SESSION_URL_OUTCOME_SUFFIX=/esito
SESSION_URL_CANCEL_SUFFIX=/cancel
SESSION_URL_NOTIFICATION_URL=http://localhost:1234/{orderId}/{sessionToken}

# Redis Config
REDIS_HOST=pagopa-ecommerce-redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
